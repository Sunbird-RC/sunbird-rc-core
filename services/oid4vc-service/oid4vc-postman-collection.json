{
  "info": {
    "name": "Sunbird RC - OID4VC (VCI + VP) Flows",
    "description": "Full OID4VCI issuance + OID4VP presentation flows against oid4vc-service, identity-service, credential-schema, and credentials-service. Run folders top-to-bottom via Collection Runner. Requires the stack up per TESTING.md (db, vault, redis, identity, credential-schema, credential, oid4vc-service).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "identity_base", "value": "http://localhost:3332" },
    { "key": "schema_base", "value": "http://localhost:3333" },
    { "key": "credential_base", "value": "http://localhost:3000" },
    { "key": "oid4vc_base", "value": "http://localhost:3400" },
    { "key": "issuer_did", "value": "" },
    { "key": "holder_did", "value": "" },
    { "key": "impostor_did", "value": "" },
    { "key": "schema_id", "value": "" },
    { "key": "offer_id", "value": "" },
    { "key": "pre_auth_code", "value": "" },
    { "key": "access_token", "value": "" },
    { "key": "c_nonce", "value": "" },
    { "key": "pop_jwt", "value": "" },
    { "key": "issued_credential", "value": "" },
    { "key": "vp_transaction_id", "value": "" },
    { "key": "vp_request_uri", "value": "" },
    { "key": "vp_nonce", "value": "" },
    { "key": "vp_state", "value": "" },
    { "key": "vp_jwt", "value": "" }
  ],
  "item": [
    {
      "name": "0. Discovery",
      "item": [
        {
          "name": "Health check",
          "request": { "method": "GET", "url": "{{oid4vc_base}}/health" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('status UP', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "Issuer metadata",
          "request": { "method": "GET", "url": "{{oid4vc_base}}/.well-known/openid-credential-issuer" }
        },
        {
          "name": "AS metadata",
          "request": { "method": "GET", "url": "{{oid4vc_base}}/.well-known/openid-configuration" }
        },
        {
          "name": "JWKS",
          "request": { "method": "GET", "url": "{{oid4vc_base}}/.well-known/jwks.json" }
        }
      ]
    },
    {
      "name": "1. Setup - Schema + DIDs",
      "item": [
        {
          "name": "Generate issuer DID",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{identity_base}}/did/generate",
            "body": { "mode": "raw", "raw": "{\"content\":[{\"alsoKnownAs\":[\"postman-issuer\"],\"services\":[],\"method\":\"rcw\"}]}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('issuer_did', json[0].id);",
            "pm.test('issuer DID generated', () => pm.expect(json[0].id).to.include('did:rcw:'));"
          ]}}]
        },
        {
          "name": "Generate holder DID",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{identity_base}}/did/generate",
            "body": { "mode": "raw", "raw": "{\"content\":[{\"alsoKnownAs\":[\"postman-holder\"],\"services\":[],\"method\":\"rcw\"}]}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('holder_did', json[0].id);"
          ]}}]
        },
        {
          "name": "Generate impostor DID (for VP negative test)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{identity_base}}/did/generate",
            "body": { "mode": "raw", "raw": "{\"content\":[{\"alsoKnownAs\":[\"postman-impostor\"],\"services\":[],\"method\":\"rcw\"}]}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('impostor_did', json[0].id);"
          ]}}]
        },
        {
          "name": "Create OID4VCI-enabled schema",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{schema_base}}/credential-schema",
            "body": { "mode": "raw", "raw": "{\n  \"schema\": {\n    \"type\": \"https://w3c-ccg.github.io/vc-json-schemas/\",\n    \"version\": \"1.0.0\",\n    \"id\": \"{{$guid}}\",\n    \"name\": \"OID4VC Pilot Credential\",\n    \"author\": \"{{issuer_did}}\",\n    \"authored\": \"2026-01-01T00:00:00.000Z\",\n    \"schema\": {\n      \"$id\": \"OID4VC-Pilot-Credential-1.0\",\n      \"$schema\": \"https://json-schema.org/draft/2019-09/schema\",\n      \"description\": \"Pilot credential for OID4VC Postman collection testing\",\n      \"type\": \"object\",\n      \"properties\": { \"name\": { \"type\": \"string\" } },\n      \"required\": [\"name\"],\n      \"additionalProperties\": true\n    }\n  },\n  \"tags\": [\"oid4vc-pilot\"],\n  \"status\": \"PUBLISHED\",\n  \"oid4vciConfig\": {\n    \"oid4vciEnabled\": true,\n    \"oid4vciFormats\": [\"ldp_vc\", \"jwt_vc_json\"],\n    \"display\": [{ \"name\": \"OID4VC Pilot Credential\", \"locale\": \"en-US\" }]\n  }\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('schema_id', json.schema.id);",
            "pm.test('schema created', () => pm.response.to.have.status(201));"
          ]}}]
        },
        {
          "name": "Verify oid4vci-configs lists the schema",
          "request": { "method": "GET", "url": "{{schema_base}}/credential-schema/oid4vci-configs" },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "pm.test('schema present with both formats', () => {",
            "  const entry = json.find(s => s.schemaId === pm.collectionVariables.get('schema_id'));",
            "  pm.expect(entry).to.not.be.undefined;",
            "  pm.expect(entry.formats).to.include('jwt_vc_json');",
            "});"
          ]}}]
        }
      ]
    },
    {
      "name": "2. OID4VCI - VC Issuance Flow (jwt_vc_json)",
      "item": [
        {
          "name": "Create offer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{oid4vc_base}}/oid4vc/offer",
            "body": { "mode": "raw", "raw": "{\n  \"credential_configuration_id\": \"OID4VC Pilot Credential\",\n  \"format\": \"jwt_vc_json\",\n  \"claims\": { \"name\": \"Postman Test Holder\" }\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "const grant = json.credential_offer.grants['urn:ietf:params:oauth:grant-type:pre-authorized_code'];",
            "pm.collectionVariables.set('pre_auth_code', grant['pre-authorized_code']);",
            "pm.collectionVariables.set('offer_id', json.offer_id);",
            "pm.test('offer created', () => pm.expect(json.offer_id).to.not.be.undefined);",
            "pm.test('credential_configuration_ids matches metadata key', () => {",
            "  pm.expect(json.credential_offer.credential_configuration_ids[0]).to.eql('OID4VC Pilot Credential_jwt_vc_json');",
            "});"
          ]}}]
        },
        {
          "name": "Dereference offer (wallet)",
          "request": { "method": "GET", "url": "{{oid4vc_base}}/oid4vc/offer/{{offer_id}}" },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "pm.test('offer dereferences with matching grant', () => {",
            "  pm.response.to.have.status(200);",
            "  const grant = json.grants['urn:ietf:params:oauth:grant-type:pre-authorized_code'];",
            "  pm.expect(grant['pre-authorized_code']).to.eql(pm.collectionVariables.get('pre_auth_code'));",
            "});"
          ]}}]
        },
        {
          "name": "Exchange pre-auth code for token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "url": "{{oid4vc_base}}/oid4vc/token",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "urn:ietf:params:oauth:grant-type:pre-authorized_code" },
                { "key": "pre-authorized_code", "value": "{{pre_auth_code}}" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('access_token', json.access_token);",
            "pm.collectionVariables.set('c_nonce', json.c_nonce);",
            "pm.test('token minted', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "Sign holder PoP JWT (via identity-service, stand-in for wallet)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{identity_base}}/utils/sign-jwt",
            "body": { "mode": "raw", "raw": "{\n  \"DID\": \"{{holder_did}}\",\n  \"payload\": { \"aud\": \"{{oid4vc_base}}\", \"nonce\": \"{{c_nonce}}\" },\n  \"header\": { \"typ\": \"openid4vci-proof+jwt\" }\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('pop_jwt', json.jwt);"
          ]}}]
        },
        {
          "name": "Request credential",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{oid4vc_base}}/oid4vc/credential",
            "body": { "mode": "raw", "raw": "{\n  \"proof\": { \"proof_type\": \"jwt\", \"jwt\": \"{{pop_jwt}}\" }\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('issued_credential', json.credential);",
            "pm.test('credential issued', () => pm.expect(json.format).to.eql('jwt_vc_json'));"
          ]}}]
        },
        {
          "name": "Verify issued credential",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{credential_base}}/credentials/verify",
            "body": { "mode": "raw", "raw": "{\n  \"verifiableCredential\": \"{{issued_credential}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "pm.test('proof OK, not expired', () => {",
            "  pm.expect(json.checks[0].proof).to.eql('OK');",
            "  pm.expect(json.checks[0].expired).to.eql('OK');",
            "});"
          ]}}]
        }
      ]
    },
    {
      "name": "3. OID4VCI - Negative Tests",
      "item": [
        {
          "name": "N1 - Replay pre-auth code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "url": "{{oid4vc_base}}/oid4vc/token",
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "grant_type", "value": "urn:ietf:params:oauth:grant-type:pre-authorized_code" },
              { "key": "pre-authorized_code", "value": "{{pre_auth_code}}" }
            ]}
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('400 bad or used code', () => {",
            "  pm.response.to.have.status(400);",
            "  pm.expect(pm.response.json().message).to.include('bad or used code');",
            "});"
          ]}}]
        },
        {
          "name": "N7 - Unknown credential_configuration_id",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{oid4vc_base}}/oid4vc/offer",
            "body": { "mode": "raw", "raw": "{\"credential_configuration_id\":\"Nonexistent Credential\",\"format\":\"jwt_vc_json\",\"claims\":{}}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('404 not enabled', () => pm.response.to.have.status(404));"
          ]}}]
        },
        {
          "name": "N8 - Unsupported format",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{oid4vc_base}}/oid4vc/offer",
            "body": { "mode": "raw", "raw": "{\"credential_configuration_id\":\"OID4VC Pilot Credential\",\"format\":\"vc+sd-jwt\",\"claims\":{}}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('400 format not supported', () => pm.response.to.have.status(400));"
          ]}}]
        },
        {
          "name": "N9 - Dereference unknown offer",
          "request": { "method": "GET", "url": "{{oid4vc_base}}/oid4vc/offer/00000000-0000-0000-0000-000000000000" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('404 not found or expired', () => pm.response.to.have.status(404));"
          ]}}]
        },
        {
          "name": "N4 - Missing Authorization header on /credential",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{oid4vc_base}}/oid4vc/credential",
            "body": { "mode": "raw", "raw": "{\"proof\":{\"proof_type\":\"jwt\",\"jwt\":\"x\"}}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('401 missing bearer token', () => pm.response.to.have.status(401));"
          ]}}]
        }
      ]
    },
    {
      "name": "4. OID4VP - VP Presentation Flow",
      "item": [
        {
          "name": "Verifier creates DCQL request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{oid4vc_base}}/vp/request",
            "body": { "mode": "raw", "raw": "{\n  \"dcql_query\": {\n    \"credentials\": [{ \"id\": \"pilot_cred\", \"format\": \"jwt_vc_json\", \"claims\": [{ \"path\": [\"name\"] }] }]\n  }\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('vp_transaction_id', json.transaction_id);",
            "pm.collectionVariables.set('vp_request_uri', json.request_uri);"
          ]}}]
        },
        {
          "name": "Wallet fetches signed request object (JAR)",
          "request": { "method": "GET", "url": "{{vp_request_uri}}" },
          "event": [{ "listen": "test", "script": { "exec": [
            "// Decode the JWT payload (no signature verification needed here, just reading claims)",
            "const jwt = pm.response.text();",
            "const parts = jwt.split('.');",
            "function b64urlDecode(str) {",
            "  str = str.replace(/-/g, '+').replace(/_/g, '/');",
            "  while (str.length % 4) str += '=';",
            "  return decodeURIComponent(atob(str).split('').map(c => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)).join(''));",
            "}",
            "const payload = JSON.parse(b64urlDecode(parts[1]));",
            "pm.collectionVariables.set('vp_nonce', payload.nonce);",
            "pm.collectionVariables.set('vp_state', payload.state);",
            "pm.test('JAR has nonce+state+dcql_query', () => {",
            "  pm.expect(payload.nonce).to.not.be.undefined;",
            "  pm.expect(payload.dcql_query).to.not.be.undefined;",
            "});"
          ]}}]
        },
        {
          "name": "Sign VP token (via identity-service, stand-in for wallet)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{identity_base}}/utils/sign-jwt",
            "body": { "mode": "raw", "raw": "{\n  \"DID\": \"{{holder_did}}\",\n  \"payload\": {\n    \"aud\": \"{{oid4vc_base}}\",\n    \"nonce\": \"{{vp_nonce}}\",\n    \"vp\": { \"verifiableCredential\": [\"{{issued_credential}}\"] }\n  },\n  \"header\": { \"typ\": \"JWT\" }\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('vp_jwt', json.jwt);"
          ]}}]
        },
        {
          "name": "Submit VP (direct_post)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{oid4vc_base}}/vp/response",
            "body": { "mode": "raw", "raw": "{\n  \"state\": \"{{vp_state}}\",\n  \"vp_token\": \"{{vp_jwt}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('status ok', () => {",
            "  pm.response.to.have.status(200);",
            "  pm.expect(pm.response.json().status).to.eql('ok');",
            "});"
          ]}}]
        },
        {
          "name": "Verifier polls status",
          "request": { "method": "GET", "url": "{{oid4vc_base}}/vp/status/{{vp_transaction_id}}" },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "pm.test('all 6 checks OK', () => {",
            "  pm.expect(json.verified).to.eql(true);",
            "  ['holderSignature','nonce','credentialSignatures','holderBinding','revocation','dcql'].forEach(k => {",
            "    pm.expect(json.checks[k]).to.eql('OK');",
            "  });",
            "});"
          ]}}]
        }
      ]
    },
    {
      "name": "5. OID4VP - Negative Tests",
      "item": [
        {
          "name": "N14 - Unknown state",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{oid4vc_base}}/vp/response",
            "body": { "mode": "raw", "raw": "{\"state\":\"totally-bogus-state\",\"vp_token\":\"x\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('400 unknown or expired state', () => pm.response.to.have.status(400));"
          ]}}]
        },
        {
          "name": "N16 - Unknown VP transaction status",
          "request": { "method": "GET", "url": "{{oid4vc_base}}/vp/status/00000000-0000-0000-0000-000000000000" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('404 transaction not found', () => pm.response.to.have.status(404));"
          ]}}]
        },
        {
          "name": "N20 - Replay already-verified VP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{oid4vc_base}}/vp/response",
            "body": { "mode": "raw", "raw": "{\n  \"state\": \"{{vp_state}}\",\n  \"vp_token\": \"{{vp_jwt}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('400 transaction not pending (replay rejected)', () => pm.response.to.have.status(400));"
          ]}}]
        },
        {
          "name": "N19 setup (a) - Verifier creates a fresh DCQL request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{oid4vc_base}}/vp/request",
            "body": { "mode": "raw", "raw": "{\n  \"dcql_query\": {\n    \"credentials\": [{ \"id\": \"pilot_cred\", \"format\": \"jwt_vc_json\", \"claims\": [{ \"path\": [\"name\"] }] }]\n  }\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('vp_transaction_id', json.transaction_id);",
            "pm.collectionVariables.set('vp_request_uri', json.request_uri);"
          ]}}]
        },
        {
          "name": "N19 setup (b) - Wallet fetches the fresh JAR",
          "request": { "method": "GET", "url": "{{vp_request_uri}}" },
          "event": [{ "listen": "test", "script": { "exec": [
            "const jwt = pm.response.text();",
            "const parts = jwt.split('.');",
            "function b64urlDecode(str) {",
            "  str = str.replace(/-/g, '+').replace(/_/g, '/');",
            "  while (str.length % 4) str += '=';",
            "  return decodeURIComponent(atob(str).split('').map(c => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)).join(''));",
            "}",
            "const payload = JSON.parse(b64urlDecode(parts[1]));",
            "pm.collectionVariables.set('vp_nonce', payload.nonce);",
            "pm.collectionVariables.set('vp_state', payload.state);"
          ]}}]
        },
        {
          "name": "N19 setup (c) - Impostor signs someone else's credential",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{identity_base}}/utils/sign-jwt",
            "body": { "mode": "raw", "raw": "{\n  \"DID\": \"{{impostor_did}}\",\n  \"payload\": {\n    \"aud\": \"{{oid4vc_base}}\",\n    \"nonce\": \"{{vp_nonce}}\",\n    \"vp\": { \"verifiableCredential\": [\"{{issued_credential}}\"] }\n  },\n  \"header\": { \"typ\": \"JWT\" }\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.collectionVariables.set('vp_jwt', pm.response.json().jwt);"
          ]}}]
        },
        {
          "name": "N19 - Submit impostor VP (holder-binding mismatch)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{oid4vc_base}}/vp/response",
            "body": { "mode": "raw", "raw": "{\n  \"state\": \"{{vp_state}}\",\n  \"vp_token\": \"{{vp_jwt}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('403 holder binding failed', () => {",
            "  pm.response.to.have.status(403);",
            "  pm.expect(pm.response.json().error).to.include('holder binding failed');",
            "});"
          ]}}]
        }
      ]
    }
  ]
}
