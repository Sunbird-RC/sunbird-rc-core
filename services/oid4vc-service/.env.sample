# Server
PORT=3400
# Public base URL of this service (used in issuer metadata + offer URIs)
PUBLIC_URL=http://localhost:3400

# Existing Sunbird RC services (unchanged contracts)
CREDENTIAL_SERVICE_BASE_URL=http://localhost:3000
IDENTITY_BASE_URL=http://localhost:3332
SCHEMA_BASE_URL=http://localhost:3333

# Session store: 'memory' (single-instance / test) or 'redis' (production)
SESSION_STORE=memory
REDIS_URL=redis://localhost:6379

# The issuer DID used to sign access tokens / request objects.
# Leave blank to auto-generate one on first boot (dev only).
ISSUER_DID=

# Feature flags
OID4VP_ENABLED=true
# Emit OID4VCI draft-13 shapes for MOSIP Inji Wallet interop
DRAFT13_COMPAT_MODE=false

# Bearer auth on internal endpoints (offer, vp/request, vp/status)
ENABLE_AUTH=false
JWKS_URI=

# TTLs (seconds)
OFFER_TTL=600
NONCE_TTL=300
ACCESS_TOKEN_TTL=300
DEFERRED_TTL=86400
VP_TXN_TTL=300
